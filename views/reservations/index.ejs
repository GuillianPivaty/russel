<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Réservations — Catway #<%= catway.catwayNumber %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { page: 'catways' }) %>
  <div class="container">
    <div class="page-header">
      <h1>Réservations — Catway #<%= catway.catwayNumber %></h1>
      <div style="display:flex; gap: 0.5rem;">
        <a href="/catways/<%= catway._id %>/reservations/new" class="btn btn-primary">+ Nouvelle réservation</a>
        <a href="/catways/<%= catway._id %>" class="btn btn-secondary">← Catway</a>
      </div>
    </div>
    <div class="card">
      <% if (reservations.length === 0) { %>
        <div class="empty-state"><div class="icon">📭</div><p>Aucune réservation.</p></div>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Client</th><th>Bateau</th><th>Début</th><th>Fin</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% reservations.forEach(r => { %>
            <tr>
              <td><%= r.clientName %></td>
              <td><%= r.boatName %></td>
              <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
              <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
              <td>
                <a href="/catways/<%= catway._id %>/reservations/<%= r._id %>" class="btn btn-secondary btn-sm">Détail</a>
                <form action="/catways/<%= catway._id %>/reservations/<%= r._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer ?')">
                  <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>
