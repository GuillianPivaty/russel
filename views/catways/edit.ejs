<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modifier catway #<%= catway.catwayNumber %> — Port de Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { page: 'catways' }) %>
  <div class="container">
    <div class="page-header">
      <h1>Modifier l'état — Catway #<%= catway.catwayNumber %></h1>
      <a href="/catways/<%= catway._id %>" class="btn btn-secondary">← Retour</a>
    </div>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <div class="form-card">
      <p style="margin-bottom: 1rem; font-size: 0.85rem; color: var(--muted);">
        Le numéro (<strong>#<%= catway.catwayNumber %></strong>) et le type (<strong><%= catway.catwayType %></strong>) ne sont pas modifiables.
      </p>
      <form action="/catways/<%= catway._id %>?_method=PUT" method="POST">
        <div class="form-group">
          <label for="catwayState">État du catway</label>
          <textarea id="catwayState" name="catwayState" required><%= catway.catwayState %></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <a href="/catways/<%= catway._id %>" class="btn btn-secondary">Annuler</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
