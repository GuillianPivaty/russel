<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modifier <%= user.username %> — Port de Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { page: 'users' }) %>
  <div class="container">
    <div class="page-header">
      <h1>Modifier <%= user.username %></h1>
      <a href="/users/<%= encodeURIComponent(user.email) %>" class="btn btn-secondary">← Retour</a>
    </div>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <div class="form-card">
      <form action="/users/<%= encodeURIComponent(user.email) %>?_method=PUT" method="POST">
        <div class="form-group">
          <label for="username">Nom d'utilisateur</label>
          <input type="text" id="username" name="username" value="<%= user.username %>" required minlength="3">
        </div>
        <div class="form-group">
          <label for="email">Adresse email</label>
          <input type="email" id="email" name="email" value="<%= user.email %>" required>
        </div>
        <div class="form-group">
          <label for="password">Nouveau mot de passe <span style="color:var(--muted); font-weight:400;">(laisser vide pour ne pas changer)</span></label>
          <input type="password" id="password" name="password" minlength="6" placeholder="••••••••">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <a href="/users/<%= encodeURIComponent(user.email) %>" class="btn btn-secondary">Annuler</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
