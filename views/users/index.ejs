<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Utilisateurs — Port de Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar', { page: 'users' }) %>
  <div class="container">
    <div class="page-header">
      <h1>👤 Utilisateurs</h1>
      <a href="/users/new" class="btn btn-primary">+ Nouvel utilisateur</a>
    </div>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <div class="card">
      <% if (users.length === 0) { %>
        <div class="empty-state"><div class="icon">👤</div><p>Aucun utilisateur.</p></div>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Nom d'utilisateur</th><th>Email</th><th>Créé le</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
            <tr>
              <td><strong><%= u.username %></strong></td>
              <td><%= u.email %></td>
              <td><%= new Date(u.createdAt).toLocaleDateString('fr-FR') %></td>
              <td>
                <a href="/users/<%= encodeURIComponent(u.email) %>" class="btn btn-secondary btn-sm">Détail</a>
                <a href="/users/<%= encodeURIComponent(u.email) %>/edit" class="btn btn-secondary btn-sm">Modifier</a>
                <form action="/users/<%= encodeURIComponent(u.email) %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                  <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>
